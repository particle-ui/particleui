# ── Database ──────────────────────────────────────────────────────────────────
# Neon Postgres — get from console.neon.tech
DATABASE_URL=

# ── Authentication (Clerk) ────────────────────────────────────────────────────
# Get from dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ── AI (Anthropic) ────────────────────────────────────────────────────────────
# Required for /generate and the MCP generate tool
# Get from console.anthropic.com
ANTHROPIC_API_KEY=

# ── Payments (Lemon Squeezy) ──────────────────────────────────────────────────
# Get from app.lemonsqueezy.com → Settings → API
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_WEBHOOK_SECRET=
LEMONSQUEEZY_PRO_VARIANT_ID=
LEMONSQUEEZY_TEAM_VARIANT_ID=

# ── Local development ─────────────────────────────────────────────────────────
# Dev token for testing Pro components locally (bypasses DB auth)
PARTICLEUI_DEV_TOKEN=
