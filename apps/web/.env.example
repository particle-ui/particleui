# ── Database ──────────────────────────────────────────────────────────────────
# Neon Postgres — get from console.neon.tech
DATABASE_URL=

# ── Authentication (Clerk) ────────────────────────────────────────────────────
# Get from dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ── AI (Anthropic) ────────────────────────────────────────────────────────────
# Required for /generate and the MCP generate tool
# Get from console.anthropic.com
ANTHROPIC_API_KEY=

# ── Payments (Stripe) ─────────────────────────────────────────────────────────
# Get from dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_live_...
# Get from dashboard.stripe.com → Developers → Webhooks → Add endpoint
# Endpoint URL: https://particleui.dev/api/stripe/webhook
# Events: checkout.session.completed, charge.refunded
STRIPE_WEBHOOK_SECRET=whsec_...
# Create Products in Stripe Dashboard → copy the Price IDs (price_...)
STRIPE_PRO_PRICE_ID=price_...
STRIPE_TEAM_PRICE_ID=price_...
# Public-facing URL (no trailing slash)
NEXT_PUBLIC_APP_URL=https://particleui.dev

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Get from resend.com → API Keys
# Used to email the API token after purchase
RESEND_API_KEY=re_...

# ── Local development ─────────────────────────────────────────────────────────
# Dev token for testing Pro components locally (bypasses DB auth)
PARTICLEUI_DEV_TOKEN=pui_dev_yourtokenhere
# Set to http://localhost:3000 locally
NEXT_PUBLIC_APP_URL=http://localhost:3000
